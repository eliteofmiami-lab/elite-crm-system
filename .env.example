# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env (já está no .gitignore).

# --- GoHighLevel (API v2) ---
# Private Integration token da subconta da Elite (Settings > Private Integrations)
GHL_API_TOKEN=
# Location ID da subconta da Elite (Settings > Business Info, ou na URL /location/<id>/)
GHL_LOCATION_ID=

# --- Urable (investigar se há API) ---
URABLE_API_KEY=

# --- Anthropic (análise de transcrições, modelo Sonnet) ---
ANTHROPIC_API_KEY=

# --- Deepgram (transcrição de áudio, modelo nova + diarização) ---
DEEPGRAM_API_KEY=

# --- Supabase (estado do worker + painel) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Painel: telefone do Eugene p/ nudges por SMS ---
EUGENE_PHONE=
